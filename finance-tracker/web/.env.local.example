# Supabase — from the Supabase project dashboard (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Public site URL used for magic-link redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Plaid — sandbox credentials from the Plaid dashboard (Team Settings → Keys)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# 32-byte key for encrypting Plaid access tokens at rest. Generate with:
#   openssl rand -base64 32
PLAID_TOKEN_ENC_KEY=
